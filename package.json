{
  "name": "poliplan",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite-node scripts/prerender-public-pages.ts",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.ts\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:import": "vitest run scripts/import-schedule/tests",
    "check:schedule-source": "tsx scripts/schedule-source/index.ts",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "import:schedule": "tsx scripts/import-schedule/index.ts",
    "admin:verify": "tsx scripts/admin/verify-supabase.ts",
    "admin:verify-auth-email": "tsx scripts/admin/verify-auth-email-hook.ts",
    "admin:fresh-start": "tsx scripts/admin/fresh-start.ts",
    "admin:fresh-start:dry": "tsx scripts/admin/fresh-start.ts --dry-run",
    "admin:verify-careers": "tsx scripts/admin/verify-careers.ts",
    "admin:import-2025-periods": "tsx scripts/admin/import-2025-periods.ts",
    "admin:import-2025-periods:dry": "tsx scripts/admin/import-2025-periods.ts --dry-run",
    "admin:notify-schedule": "tsx scripts/admin/notify-schedule-update.ts",
    "import:grading-scale": "node scripts/import-grading-scale.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "commander": "^15.0.0",
    "dexie": "^4.0.11",
    "lucide-react": "^0.511.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.6.2",
    "xlsx": "^0.18.5",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fake-indexeddb": "^6.0.0",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.33.1",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.2.3"
  }
}
