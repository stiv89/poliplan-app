# Credenciales de administración (no commitear .env.admin).
# Copiá este archivo a .env.admin y completá la service role key.
#
# Dashboard → Project Settings → API → service_role (secret)
#
# Luego:
#   npm run admin:fresh-start:dry   # simular import
#   npm run admin:fresh-start       # limpiar + importar Excel 2026
#   npm run admin:verify            # conteos en Supabase
#   npm run admin:notify-schedule   # probar avisos de horario por correo
#
# Correos (Brevo) — también como secrets de Edge Functions en Supabase:
#   BREVO_API_KEY o BREVOKEY
#   EMAIL_FROM=noreply@poliplan.app
#   EMAIL_FROM_NAME=PoliPlan
#   APP_URL=https://poliplan.app
#   SEND_EMAIL_HOOK_SECRET=...   # Auth hook Send Email

SUPABASE_URL=https://sfyovljgzriaquguygte.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
BREVO_API_KEY=
APP_URL=https://poliplan.app
EMAIL_FROM=noreply@poliplan.app
EMAIL_FROM_NAME=PoliPlan
