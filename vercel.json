{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.poliplan.app" }],
      "destination": "https://poliplan.app/:path*",
      "permanent": true
    },
    { "source": "/app", "destination": "/", "permanent": true },
    { "source": "/app/:path*", "destination": "/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!assets|email|data|presentacion|horarios-fpuna|examenes-fpuna|calculadora-notas-fpuna|como-funciona|fuentes|aviso-legal|.*\\..*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
