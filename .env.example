# Supabase (solo claves públicas en el frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Modo desarrollo: usar datos locales de sample-schedule.json
VITE_USE_SAMPLE_DATA=true

# URL externa para el botón Donar en la landing (Mercado Pago, Ko-fi, etc.)
VITE_DONATE_URL=

# ==================================================
# Variables administrativas (solo scripts Node / CI)
# NO usar en Vite ni commitear valores reales
# ==================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Umbrales opcionales del importador
MAX_REJECTED_ROWS_PERCENT=15
MIN_COURSES=5
MIN_SECTIONS=10
MAX_DROP_PERCENT=40
